# Copy this file to .env and adjust values before running docker compose.
# .env is read automatically by docker compose.

POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Use a long, random value in real deployments (32+ chars for HS256).
JWT_SECRET=change-this-dev-secret-please-32chars

# Shared secret used by Service A to call Service B, and by Service B
# to reject any request that doesn't include it in X-Internal-Token.
INTERNAL_TOKEN=change-this-internal-token
